#!/usr/bin/env ruby
# frozen_string_literal: true

$stdout.sync = true

require_relative "../lib/zero_x_da/market_broker_bot/bot"
require_relative "../lib/zero_x_da/market_broker_bot/telegram_api"

public_url = ENV.fetch("RENDER_EXTERNAL_URL") { ENV.fetch("PUBLIC_URL") }.delete_suffix("/")
telegram = ZeroXDA::MarketBrokerBot::TelegramAPI.new(
  token: ENV.fetch("TELEGRAM_BOT_TOKEN")
)
telegram.set_webhook(
  url: "#{public_url}/telegram/webhook",
  secret_token: ENV.fetch("TELEGRAM_WEBHOOK_SECRET")
)
telegram.set_commands(
  ZeroXDA::MarketBrokerBot::Bot::START_COMMANDS,
  scope: { type: "default" }
)
puts "Telegram webhook configured: #{public_url}/telegram/webhook"

exec("bundle", "exec", "puma", "-C", "config/puma.rb", "config.ru")
